# Gemeinsame Aliase für Bash und Zsh

# eza statt ls
if command -v eza >/dev/null 2>&1; then
    alias ls="eza -l -a --git"
else
    alias ls="ls -la --color=auto"
fi

# bat statt cat
if command -v bat >/dev/null 2>&1; then
    alias cat="bat"
fi

# fd statt find
if command -v fd >/dev/null 2>&1; then
    alias find="fd"
fi

# Bitwarden CLI Helfer
bw-unlock() {
    export BW_SESSION=$(bw unlock --raw)
    echo "Bitwarden entsperrt! Session-Key geladen."
}

# Lade privaten ssh key
ssh-load-bw() {
    if [ -z "$BW_SESSION" ]; then
        export BW_SESSION=$(bw unlock --raw)
    fi
    local key_id="${1:-43472dbe-f1d3-49b2-bf7e-b4850069cc7b}"
    bw get item "$key_id" | jq -r '.sshKey.privateKey' | ssh-add -
}
